// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("ADMIN") // ADMIN, FINANCE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id             String    @id @default(uuid())
  name           String
  cpf            String    @unique
  type           String    // "PJ" or "CLT"
  role           String    
  baseSalary     Float     // Salário base
  transportDaily Float?    // Valor diário do VT (geralmente usado pro PJ)
  gasAssistance  Float?    // Ajuda de Custo (Gasolina) Fixo por mês
  pixKey         String?   // Chave Pix do colaborador
  paymentMethod  String    @default("PIX") // PIX or TRANSFER
  bankName       String?   // Ex: Nubank, Itaú
  accountType    String?   // Corrente, Poupança, Salário
  agency         String?   // Agência
  accountNumber  String?   // Número da conta
  recurringDeductions Float @default(0) // Descontos perenes/fixos (ex: Plano de saúde)
  temporaryDeductions Float @default(0) // Descontos por período determinado (ex: Adiantamento)
  temporaryDeductionsDesc String?       // Descrição do desconto temporário (ex: "Adiantamento 1/3")
  temporaryDeductionsExpiration String? // Mês de expiração no formato "YYYY-MM"
  hourlyRate     Float?    // Para horistas/aulistas
  cestaBasica    Float?    // Valor do benefício de cesta básica
  isAulista      Boolean   @default(false)
  salaryAdvance  Float     @default(0) // Valor fixo de adiantamento salarial (pago todo dia 20)
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  payrolls       Payroll[]
  advances       PayrollAdvance[]
}

model Payroll {
  id             String    @id @default(uuid())
  employeeId     String
  employee       Employee  @relation(fields: [employeeId], references: [id])
  
  month          Int       // 1 a 12
  year           Int       // Ex: 2026
  
  // Detalhes do cálculo
  baseSalary     Float
  workingDays    Int?      // Dias úteis no mês (para folha base se necessário) ou VT
  transportTotal Float?    // (workingDays - absencesVT) * transportDaily
  absences       Int       @default(0) // Faltas (Salário Mês fechado)
  absenceDeduction Float   @default(0) // Desconto por faltas: (baseSalary/30) * absences
  absencesVT     Int       @default(0) // Faltas (Período VT 08 a 07)
  transportDeduction Float @default(0) // Desconto de VT: absencesVT * transportDaily
  otherDeductions Float    @default(0) // Outros descontos gerais
  bonuses        Float     @default(0) // Acréscimos
  grossEarnings  Float     @default(0) // Total de Proventos (para CLT)
  inssDeduction  Float     @default(0) // Valor descontado de INSS (para CLT)
  irrfDeduction  Float     @default(0) // Valor descontado de IRRF (para CLT)
  fgtsValue      Float     @default(0) // Valor depositado de FGTS (para CLT)
  salaryAdvance  Float     @default(0) // Adiantamento salarial (para CLT)
  hoursAulista   Float?    // Horas aula registradas para professores
  
  netTotal       Float     // Total Líquido
  status         String    @default("PENDING") // PENDING, PAID
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([employeeId, month, year])
}

model PayrollAdvance {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])

  month       Int      // 1-12
  year        Int      // Ex: 2026
  amount      Float    // Valor do adiantamento

  status      String   @default("PENDING") // PENDING | PAID
  paidAt      DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([employeeId, month, year])
}

model FinancialTransaction {
  id          String   @id @default(uuid())
  title       String
  type        String   // "INCOME" (Receita), "EXPENSE" (Despesa)
  amount      Float
  category    String   // Ex: "MENSALIDADE", "MATERIAL", "FOLHA"
  date        DateTime
  status      String   @default("PAID") // PENDING, PAID
  description String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Contract {
  id          String   @id @default(uuid())
  clientName  String
  document    String   // CPF/CNPJ
  title       String
  content     String   // O conteúdo do contrato ou template preenchido
  status      String   @default("DRAFT") // DRAFT, ACTIVE, EXPIRED
  startDate   DateTime
  endDate     DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
